print(X.columns)


X = train.drop(columns=["id", "Rings"])
X_test = test.drop(columns=["id"])


from patsy import dmatrix

# Create spline basis using the Length variable
X_train_spline = dmatrix(
    "bs(Length, df=6, degree=3, include_intercept=False)",
    {"Length": X_train["Length"]},
    return_type="dataframe"
)

X_valid_spline = dmatrix(
    "bs(Length, df=6, degree=3, include_intercept=False)",
    {"Length": X_valid["Length"]},
    return_type="dataframe"
)

X_test_spline = dmatrix(
    "bs(Length, df=6, degree=3, include_intercept=False)",
    {"Length": X_test["Length"]},
    return_type="dataframe"
)


from sklearn.linear_model import LinearRegression

spline_model = LinearRegression()

spline_model.fit(
    X_train_spline,
    y_train
)


pred_spline = spline_model.predict(X_valid_spline)


from sklearn.metrics import mean_squared_error
import numpy as np

rmse_spline = np.sqrt(
    mean_squared_error(y_valid, pred_spline)
)

print("Regression Splines RMSE:", rmse_spline)


spline_predictions = spline_model.predict(X_test_spline)

submission_spline = pd.DataFrame({
    "id": test["id"],
    "Rings": spline_predictions
})

submission_spline.to_csv(
    "submission_spline.csv",
    index=False
)

