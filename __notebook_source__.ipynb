import pandas as pd

train = pd.read_csv("/kaggle/input/competitions/playground-series-s4e4/train.csv")
test = pd.read_csv("/kaggle/input/competitions/playground-series-s4e4/test.csv")

print(train.shape)
print(test.shape)

train.head()


# Display data information

train.info()

print("\nMissing Values:")
print(train.isnull().sum())

print("\nSummary Statistics:")
train.describe()


# ==========================================
# The training dataset contains 90,615 observations and 10 variables, 
# including the target variable Rings. The test dataset contains 60,411 
# observations and 9 predictor variables. No missing values were detected, 
# so no data imputation was required prior to model development.
# ==========================================


# Separate predictors and response variable

X = train.drop(columns=["Rings"])
y = train["Rings"]

X_test = test.copy()

print(X.shape)
print(y.shape)


# One-hot encode Sex

X = pd.get_dummies(X, columns=["Sex"], drop_first=True)
X_test = pd.get_dummies(X_test, columns=["Sex"], drop_first=True)

# Ensure both datasets have identical columns
X, X_test = X.align(X_test, join="left", axis=1, fill_value=0)

print(X.head())


from sklearn.model_selection import train_test_split

X_train, X_valid, y_train, y_valid = train_test_split(
    X,
    y,
    test_size=0.20,
    random_state=42
)

print(X_train.shape)
print(X_valid.shape)


from sklearn.pipeline import Pipeline
from sklearn.preprocessing import PolynomialFeatures
from sklearn.linear_model import LinearRegression

poly_model = Pipeline([
    ("poly", PolynomialFeatures(degree=2, include_bias=False)),
    ("linear", LinearRegression())
])

poly_model.fit(X_train, y_train)


# ==========================================
# Degree 2 is appropriate because it captures nonlinear
# relationships while helping avoid unnecessary overfitting.
# ==========================================


pred_poly = poly_model.predict(X_valid)


from sklearn.metrics import mean_squared_error
import numpy as np

rmse_poly = np.sqrt(mean_squared_error(y_valid, pred_poly))

print("Polynomial Regression RMSE:", rmse_poly)


import matplotlib.pyplot as plt

residuals = y_valid - pred_poly

plt.figure(figsize=(8,5))
plt.scatter(pred_poly, residuals, alpha=0.5)
plt.axhline(y=0, color='red', linestyle='--')

plt.xlabel("Predicted Rings")
plt.ylabel("Residuals")
plt.title("Residual Plot - Polynomial Regression")

plt.show()


poly_predictions = poly_model.predict(X_test)

submission_poly = pd.DataFrame({
    "id": test["id"],
    "Rings": poly_predictions
})

submission_poly.to_csv("submission_poly.csv", index=False)

